{
  "name": "comfyui-mobile-wrapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server/index.js",
    "install:comfy-node": "powershell -ExecutionPolicy Bypass -File scripts/install-mobileui-node.ps1",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "vite": "^7.2.6",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
